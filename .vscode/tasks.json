{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++: build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "C++: build and run",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build.ps1",
                "-Run"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "C++: run last build",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\sistema_irrigacao.exe",
            "problemMatcher": []
        }
    ]
}
